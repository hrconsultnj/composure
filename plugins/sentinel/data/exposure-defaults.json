{
  "_description": "Default path-based auth boundary heuristics for exposure classification. Override per-project in .claude/sentinel.json under exposureBoundaries.",
  "exposureBoundaries": {
    "public": [
      "src/app/api/public/**",
      "src/app/(public)/**",
      "app/api/public/**",
      "pages/api/public/**",
      "routes/public/**",
      "src/app/api/webhooks/**",
      "app/api/webhooks/**",
      "public/**",
      "**/views/public/**",
      "**/api/public/**",
      "**/webhooks/**",
      "**/handlers/public/**",
      "**/routers/public/**"
    ],
    "authenticated": [
      "src/app/api/**",
      "src/app/(auth)/**",
      "src/app/(dashboard)/**",
      "src/app/(protected)/**",
      "app/api/**",
      "pages/api/**",
      "routes/**",
      "src/routes/**",
      "src/pages/**",
      "**/views/**",
      "**/api/**",
      "**/endpoints/**",
      "**/routers/**",
      "**/handlers/**",
      "**/controllers/**",
      "**/cmd/server/**",
      "**/cmd/api/**"
    ],
    "internal": [
      "scripts/**",
      "tools/**",
      "migrations/**",
      "seed/**",
      "supabase/**",
      "src/lib/**",
      "src/utils/**",
      "src/helpers/**",
      "internal/**",
      "cli/**",
      "**/management/**",
      "**/management/commands/**",
      "**/tests/**",
      "**/test/**",
      "**/fixtures/**",
      "**/cmd/migrate/**",
      "**/cmd/seed/**",
      "**/pkg/internal/**"
    ]
  },
  "resolutionOrder": ["public", "authenticated", "internal"],
  "fallback": "internal"
}
