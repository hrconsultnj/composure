{
  "_comment_no_fetch_hook": "Implementation note: do not add PostToolUse hooks matching 'mcp__.*composure_fetch_.*'. Hooks emitting 'updatedMCPToolOutput' on these tools interfere with the intended tool result rendering. If you need to transform fetch results, do it inside the tool handler in enforce/src/server.ts instead.",
  "_comment_defensive_wrapper": "Every command uses the defensive pattern: `test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"...\" 2>/dev/null; exit 0`. This guarantees silent no-op when the plugin cache dir was cleaned up mid-session (anthropics/claude-code#14061, #29074, #13799, #15642, #18426). stderr is redirected to /dev/null so no 'hook error' transcript notices appear. The trailing `; exit 0` always runs because it follows a semicolon, not `&&`, so the command's final exit code is always 0 regardless of what came before. code-enforcement.mjs preserves exit 2 semantics for hard-rule blocking via an inline $EC check.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/cache-heal.sh\" 2>/dev/null; exit 0",
            "timeout": 10,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-boot.sh\" 2>/dev/null; exit 0",
            "timeout": 12,
            "statusMessage": "Booting session..."
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-auth.sh\" 2>/dev/null; exit 0",
            "timeout": 8,
            "statusMessage": "Checking authentication..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-read-clear.sh\" 2>/dev/null; exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/architecture-skill-trigger.sh\" 2>/dev/null; exit 0",
            "timeout": 5,
            "statusMessage": "Checking architecture..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/decomposition-guide.sh\" 2>/dev/null; exit 0",
            "timeout": 5,
            "statusMessage": "Checking decomposition..."
          },
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" || exit 0; node \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/code-enforcement.mjs\" 2>/dev/null; EC=$?; [ $EC -eq 2 ] && exit 2; exit 0",
            "timeout": 5,
            "statusMessage": "Enforcing code rules..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*composure.graph.*",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-read-reminder.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/quality/decomposition-check.sh\" 2>/dev/null; exit 0",
            "timeout": 10,
            "statusMessage": "Checking code quality..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-update.sh\" 2>/dev/null; exit 0",
            "timeout": 15,
            "statusMessage": "Updating code graph..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cortex/memory-fusion.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": ".*sequential.thinking.*",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cortex/seq-think-capture.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Task.*",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/task-state-writer.sh\" 2>/dev/null; exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/task-cortex-sync.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/task-cortex-sync.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-end-summary.sh\" 2>/dev/null; exit 0",
            "timeout": 5,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/subagent-tracker.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/subagent-tracker.sh\" 2>/dev/null; exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && node \"${CLAUDE_PLUGIN_ROOT}/hooks/prompt/request-classifier.mjs\" 2>/dev/null; exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}\" && node \"${CLAUDE_PLUGIN_ROOT}/hooks/session/turn-capture.mjs\" 2>/dev/null; exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ]
  }
}
