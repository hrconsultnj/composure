{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/init-check.sh\" 2>&1 || exit 0",
            "timeout": 5,
            "statusMessage": "Checking Composure setup..."
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/auth-check.sh\" 2>&1 || exit 0",
            "timeout": 8,
            "statusMessage": "Checking authentication..."
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/content-protection.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-stack-note.sh\" 2>&1 || exit 0",
            "timeout": 5,
            "statusMessage": "Detecting stack..."
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/resume-check.sh\" 2>&1 || exit 0",
            "timeout": 10,
            "statusMessage": "Checking tasks & graph..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-read-clear.sh\" 2>&1 || exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/architecture-skill-trigger.sh\" 2>&1 || { echo '[composure:pre:arch-trigger] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking architecture..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/decomposition-guide.sh\" 2>&1 || { echo '[composure:pre:decomp-guide] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking decomposition..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/no-bandaids.sh\" 2>&1 || { echo '[composure:pre:no-bandaids] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking for band-aid fixes..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/framework-validation.sh\" 2>&1 || { echo '[composure:pre:framework-validation] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Validating framework rules..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*composure.graph.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-read-reminder.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/quality/decomposition-check.sh\" 2>&1 || { echo '[composure:post:decomp-check] hook failed' >&2; exit 0; }",
            "timeout": 10,
            "statusMessage": "Checking code quality..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-update.sh\" 2>&1 || { echo '[composure:post:graph-update] hook failed' >&2; exit 0; }",
            "timeout": 15,
            "statusMessage": "Updating code graph..."
          }
        ]
      }
    ]
  }
}
