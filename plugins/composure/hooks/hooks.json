{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-boot.sh\" 2>&1 || exit 0",
            "timeout": 12,
            "statusMessage": "Booting session..."
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-auth.sh\" 2>&1 || exit 0",
            "timeout": 8,
            "statusMessage": "Checking authentication..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-read-clear.sh\" 2>&1 || exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/architecture-skill-trigger.sh\" 2>&1 || { echo '[composure:pre:arch-trigger] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking architecture..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/decomposition-guide.sh\" 2>&1 || { echo '[composure:pre:decomp-guide] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking decomposition..."
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/enforcement/code-enforcement.mjs\" 2>&1 || { EC=$?; [ $EC -eq 2 ] && exit 2; echo '[composure:pre:code-enforcement] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Enforcing code rules..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*composure.graph.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-read-reminder.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/quality/decomposition-check.sh\" 2>&1 || { echo '[composure:post:decomp-check] hook failed' >&2; exit 0; }",
            "timeout": 10,
            "statusMessage": "Checking code quality..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph/graph-update.sh\" 2>&1 || { echo '[composure:post:graph-update] hook failed' >&2; exit 0; }",
            "timeout": 15,
            "statusMessage": "Updating code graph..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cortex/memory-fusion.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": ".*sequential.thinking.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cortex/seq-think-capture.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Task.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/task-state-writer.sh\" 2>&1 || exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/task-cortex-sync.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/task-cortex-sync.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session/session-end-summary.sh\" 2>&1 || exit 0",
            "timeout": 5,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/subagent-tracker.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/task/subagent-tracker.sh\" 2>&1 || exit 0",
            "timeout": 3,
            "async": true,
            "statusMessage": ""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/prompt/request-classifier.mjs\" 2>&1 || exit 0",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      }
    ]
  }
}
