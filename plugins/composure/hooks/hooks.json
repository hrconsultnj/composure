{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/init-check.sh\" 2>&1 || exit 0",
            "timeout": 5,
            "statusMessage": "Checking Composure setup..."
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-stack-note.sh\" 2>&1 || exit 0",
            "timeout": 5,
            "statusMessage": "Detecting stack..."
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/resume-check.sh\" 2>&1 || exit 0",
            "timeout": 10,
            "statusMessage": "Checking tasks & graph..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/architecture-skill-trigger.sh\" 2>&1 || { echo '[composure:pre:arch-trigger] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking architecture..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/decomposition-guide.sh\" 2>&1 || { echo '[composure:pre:decomp-guide] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking decomposition..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/no-bandaids.sh\" 2>&1 || { echo '[composure:pre:no-bandaids] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking for band-aid fixes..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/decomposition-check.sh\" 2>&1 || { echo '[composure:post:decomp-check] hook failed' >&2; exit 0; }",
            "timeout": 10,
            "statusMessage": "Checking code quality..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/graph-update.sh\" 2>&1 || { echo '[composure:post:graph-update] hook failed' >&2; exit 0; }",
            "timeout": 15,
            "statusMessage": "Updating code graph..."
          }
        ]
      }
    ]
  }
}
