{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/init-check.sh\" 2>&1 || exit 0",
            "timeout": 5,
            "statusMessage": "Checking Design Forge setup..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/canvas-guard.sh\" 2>&1 || { echo '[design-forge:canvas-guard] hook failed' >&2; exit 0; }",
            "timeout": 5,
            "statusMessage": "Checking canvas patterns..."
          }
        ]
      }
    ]
  }
}
